{% extends 'base.html.twig' %}

{% block title %}New Announcement{% endblock %}

{% block body %}
    <h1 class="text-2xl font-bold mb-4">Post a new Company Announcement</h1>
    <form method="post" class="max-w-xl bg-white p-6 rounded shadow-md border">
        <div class="mb-4">
            <label for="title" class="block text-sm font-semibold mb-1">Title</label>
            <input type="text" name="title" id="title" class="w-full border rounded p-2" required>
        </div>
        <div class="mb-4">
            <label for="content" class="block text-sm font-semibold mb-1">Content</label>
            <textarea name="content" id="content" rows="6" class="w-full border rounded p-2" required></textarea>
        </div>
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded font-semibold hover:bg-blue-700">Publish Announcement</button>
        <a href="{{ path('app_dashboard') }}" class="ml-4 text-gray-500 underline">Cancel</a>
    </form>
{% endblock %}
